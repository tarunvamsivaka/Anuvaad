# =============================================================================
# Anuvaad Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
#
#   cp .env.example .env.local
#
# All NEXT_PUBLIC_* variables are exposed to the browser bundle.
# Never put secrets (service_role key, Razorpay key secret, etc.) here.
# =============================================================================

# ---------- Supabase ----------
# Project URL — found in Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Anon (public) key — found in Dashboard → Settings → API → Project API keys
# This key is public by design; all access is gated by Row Level Security (RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------- Backend API ----------
# URL of the Anuvaad FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------- PostHog Analytics ----------
# Project API key from PostHog → Settings → Project API Key
# Leave blank to disable analytics entirely.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key

# Set to "true" to enable PostHog capture in development (disabled by default)
# NEXT_PUBLIC_POSTHOG_DEBUG=true

# ---------- Frontend URL ----------
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# ---------- Sentry Error Monitoring ----------
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-url

