        <p>&copy; 2026 Anuvaad. All rights reserved. Sanskrit: translation</p>
        <div class="footer-socials">
          <a href="https://github.com/tarunvamsivaka/Anuvaad" target="_blank" rel="noopener noreferrer">GitHub</a>
          <span>·</span>
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer">Twitter</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Scripts Section -->
  <script>
    // Register GSAP ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);

    // 1. Initialize Lenis Smooth Scroll
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true
    });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });
    gsap.ticker.lagSmoothing(0);

    // Disable standard scroll restoration
    if (history.scrollRestoration) {
      history.scrollRestoration = 'manual';
    }

    // 2. Custom Cursor Follower
    const cursorDot = document.querySelector('.custom-cursor');
    const cursorFollower = document.querySelector('.custom-cursor-follower');
    let mouseX = -100, mouseY = -100;
    let followerX = -100, followerY = -100;

    window.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      cursorDot.style.left = mouseX + 'px';
      cursorDot.style.top = mouseY + 'px';
    });

    function updateCursorFollower() {
      followerX += (mouseX - followerX) * 0.12;
      followerY += (mouseY - followerY) * 0.12;
      cursorFollower.style.left = followerX + 'px';
      cursorFollower.style.top = followerY + 'px';
      requestAnimationFrame(updateCursorFollower);
    }
    updateCursorFollower();

    // Hover transitions for links/buttons
    document.querySelectorAll('a, button, .faq-trigger, .pricing-toggle').forEach(el => {
      el.addEventListener('mouseenter', () => {
        cursorDot.style.transform = 'translate(-50%, -50%) scale(1.5)';
        cursorDot.style.backgroundColor = 'var(--cyan-core)';
        cursorFollower.style.transform = 'translate(-50%, -50%) scale(1.4)';
        cursorFollower.style.borderColor = 'var(--cyan-core)';
      });
      el.addEventListener('mouseleave', () => {
        cursorDot.style.transform = 'translate(-50%, -50%) scale(1)';
        cursorDot.style.backgroundColor = 'var(--amber-glow)';
        cursorFollower.style.transform = 'translate(-50%, -50%) scale(1)';
        cursorFollower.style.borderColor = 'var(--amber-dim)';
      });
    });

    // 3. Loading Screen Sequence
    window.addEventListener('load', () => {
      const tl = gsap.timeline();
      tl.to(".loader-text .letter", { opacity: 1, duration: 0.4, stagger: 0.08, ease: "power2.out" })
        .to(".loader-tagline", { opacity: 1, duration: 0.6, ease: "power2.out" }, "-=0.2")
        .to("#loader", { 
          yPercent: -100, 
          duration: 1.2, 
          ease: "power4.inOut", 
          delay: 0.8,
          onComplete: () => {
            document.getElementById('loader').style.display = 'none';
            // Trigger Hero Reveals
            gsap.to(".hero-pretitle", { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" });
            gsap.to(".hero-title span", { opacity: 1, y: 0, duration: 1.0, ease: "power3.out", stagger: 0.15, delay: 0.1 });
            gsap.to(".hero-subheadline", { opacity: 1, duration: 0.8, delay: 0.4 });
            gsap.to(".hero-ctas", { opacity: 1, y: 0, duration: 0.8, delay: 0.6 });
            gsap.to(".hero-stats", { opacity: 1, y: 0, duration: 0.8, delay: 0.8, onComplete: triggerStatsCount });
          }
        });
    });

    // 4. Hero Stats Count-Up Animation
    function triggerStatsCount() {
      const stats = document.querySelectorAll('.stat-count');
      stats.forEach(stat => {
        const target = parseInt(stat.getAttribute('data-target'));
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 1.8,
          ease: "power2.out",
          onUpdate: () => {
            stat.textContent = Math.floor(obj.val) + (target === 100 ? "%" : "+");
          }
        });
      });
    }

    // 5. Navigation Scroll Gating
    let lastScrollY = window.scrollY;
    const navbar = document.querySelector('.nav-glass');
    window.addEventListener('scroll', () => {
      if (window.scrollY > lastScrollY && window.scrollY > 100) {
        navbar.classList.add('nav-hidden');
      } else {
        navbar.classList.remove('nav-hidden');
      }
      lastScrollY = window.scrollY;
    });

    // Mobile Hamburger Menu Toggle
    const mobileToggle = document.querySelector('.mobile-toggle');
    const navLinks = document.querySelector('.nav-links');
    mobileToggle.addEventListener('click', () => {
      mobileToggle.classList.toggle('active');
      const isOpen = mobileToggle.classList.contains('active');
      navLinks.style.display = isOpen ? 'flex' : 'none';
      if (isOpen) {
        navLinks.style.flexDirection = 'column';
        navLinks.style.position = 'absolute';
        navLinks.style.top = '72px';
        navLinks.style.left = '0';
        navLinks.style.width = '100vw';
        navLinks.style.background = 'var(--bg-void)';
        navLinks.style.padding = '20px';
        navLinks.style.borderBottom = '1px solid rgba(255,255,255,0.05)';
      }
    });

    // 6. Typewriter Cycle in Hero Subheadline
    const subheadlineEl = document.querySelector('.hero-subheadline-cycle');
    const typewriterTexts = [
      "Paste Python. Read English.",
      "Describe logic. Get Go code.",
      "Understand Java in 3 seconds."
    ];
    let textIdx = 0;
    let charIdx = 0;
    let isDeleting = false;
    function cycleTypewriter() {
      const currentText = typewriterTexts[textIdx];
      if (!isDeleting) {
        subheadlineEl.textContent = currentText.slice(0, charIdx + 1);
        charIdx++;
        if (charIdx === currentText.length) {
          isDeleting = true;
          setTimeout(cycleTypewriter, 2000);
          return;
        }
      } else {
        subheadlineEl.textContent = currentText.slice(0, charIdx - 1);
        charIdx--;
        if (charIdx === 0) {
          isDeleting = false;
          textIdx = (textIdx + 1) % typewriterTexts.length;
        }
      }
      setTimeout(cycleTypewriter, isDeleting ? 40 : 80);
    }
    cycleTypewriter();

    // 7. Three.js WebGL Particle background
    const canvas = document.getElementById('hero-canvas');
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 30;

    // Create character textures
    const chars = ['{ }', ';', '=', '=>', '< >', '/*', '*/', '( )', '[ ]', '::'];
    const textCanvas = document.createElement('canvas');
    textCanvas.width = 1280;
    textCanvas.height = 128;
    const ctx2d = textCanvas.getContext('2d');
    ctx2d.fillStyle = '#ffffff';
    ctx2d.font = 'bold 48px "JetBrains Mono", monospace';
    ctx2d.textAlign = 'center';
    ctx2d.textBaseline = 'middle';
    chars.forEach((char, idx) => {
      ctx2d.fillText(char, idx * 128 + 64, 64);
    });
    const texture = new THREE.CanvasTexture(textCanvas);

    // Particle Shader Material
    const particleMaterial = new THREE.ShaderMaterial({
      uniforms: {
        uTexture: { value: texture },
        uTime: { value: 0 },
        uMouse: { value: new THREE.Vector3(-9999, -9999, -9999) }
      },
      vertexShader: `
        uniform float uTime;
        uniform vec3 uMouse;
        attribute float charIndex;
        attribute vec3 particleColor;
        varying float vCharIndex;
        varying vec3 vColor;
        
        void main() {
          vCharIndex = charIndex;
          vColor = particleColor;
          
          vec3 pos = position;
          
          // Slow Y drift, wrapping between -25 and 25
          pos.y = mod(pos.y + uTime * 0.4 + 25.0, 50.0) - 25.0;
          
          // Sine wave Z breathing displacement
          pos.z += sin(pos.x * 0.15 + uTime * 0.8) * 1.5;
          
          // Mouse attraction in 3D space
          float dist = distance(pos, uMouse);
          if (dist < 12.0) {
            vec3 dir = normalize(uMouse - pos);
            float strength = (12.0 - dist) * 0.05;
            pos += dir * strength;
          }
          
          vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
          gl_PointSize = 15.0 * (300.0 / -mvPosition.z);
          gl_Position = projectionMatrix * mvPosition;
        }
      `,
      fragmentShader: `
        uniform sampler2D uTexture;
        varying float vCharIndex;
        varying vec3 vColor;
        
        void main() {
          vec2 uv = gl_PointCoord;
          
          // Select character sub-image
          float colIndex = floor(vCharIndex);
          float uStart = colIndex * 0.1;
          uv.x = uStart + (uv.x * 0.1);
          
          vec4 texColor = texture2D(uTexture, uv);
          if (texColor.a < 0.15) discard;
          
          gl_FragColor = vec4(vColor, texColor.a * 0.75);
        }
      `,
      transparent: true,
      depthWrite: false,
      blending: THREE.AdditiveBlending
    });

    const numParticles = 4000;
    const geometry = new THREE.BufferGeometry();
    const positions = new Float32Array(numParticles * 3);
    const charIndices = new Float32Array(numParticles);
    const colors = new Float32Array(numParticles * 3);

    for (let i = 0; i < numParticles; i++) {
      // Box range: 60x50x20
      positions[i * 3] = (Math.random() - 0.5) * 60;
      positions[i * 3 + 1] = (Math.random() - 0.5) * 50;
      positions[i * 3 + 2] = (Math.random() - 0.5) * 20;

      charIndices[i] = Math.floor(Math.random() * chars.length);

      // Color mapping: 60% amber (#c8860a), 40% cyan (#00d4ff)
      const isAmber = Math.random() > 0.4;
      const c = new THREE.Color(isAmber ? '#c8860a' : '#00d4ff');
      colors[i * 3] = c.r;
      colors[i * 3 + 1] = c.g;
      colors[i * 3 + 2] = c.b;
    }

    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    geometry.setAttribute('charIndex', new THREE.BufferAttribute(charIndices, 1));
    geometry.setAttribute('particleColor', new THREE.BufferAttribute(colors, 3));

    const points = new THREE.Points(geometry, particleMaterial);
    scene.add(points);

    // Track mouse coordinates for Three.js projected plane
    const mouse3D = new THREE.Vector2(-9999, -9999);
    window.addEventListener('mousemove', (e) => {
      mouse3D.x = (e.clientX / window.innerWidth) * 2 - 1;
      mouse3D.y = -(e.clientY / window.innerHeight) * 2 + 1;
    });

    const clock = new THREE.Clock();
    function animateThree() {
      requestAnimationFrame(animateThree);
      
      const elapsed = clock.getElapsedTime();
      particleMaterial.uniforms.uTime.value = elapsed;

      // Project mouse coordinates to 3D plane
      const raycaster = new THREE.Raycaster();
      raycaster.setFromCamera(mouse3D, camera);
      const plane = new THREE.Plane(new THREE.Vector3(0, 0, 1), 0);
      const intersectPoint = new THREE.Vector3();
      if (raycaster.ray.intersectPlane(plane, intersectPoint)) {
        particleMaterial.uniforms.uMouse.value.copy(intersectPoint);
      }

      points.rotation.y = elapsed * 0.02;
      points.rotation.x = Math.sin(elapsed * 0.05) * 0.02;

      renderer.render(scene, camera);
    }
    animateThree();

    // Window resizing handler
    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });

    // Helper to highlight Python stubs in Scene 1
    function highlightPython(code) {
      return code
        .replace(/(def|if|in|return|for)/g, '<span class="syn-keyword">$1</span>')
        .replace(/(\[[0-9a-zA-Z_]+\])/g, '<span class="syn-number">$1</span>')
        .replace(/(__subclasses__)/g, '<span class="syn-function">$1</span>');
    }

    // 8. GSAP Scroll Story Chapter pinning & scrubbing
    const storyTL = gsap.timeline({
      scrollTrigger: {
        trigger: "#story",
        start: "top top",
        end: "+=500%",
        scrub: 1,
        pin: true,
      }
    });

    // Helper functions to toggle active scene visuals
    function showVisualScene(index) {
      document.querySelectorAll('.scene-visual').forEach((vis, idx) => {
        if (idx === index) {
          vis.classList.add('active-visual');
          gsap.to(vis, { opacity: 1, scale: 1, duration: 0.3 });
        } else {
          vis.classList.remove('active-visual');
          gsap.to(vis, { opacity: 0, scale: 0.95, duration: 0.3 });
        }
      });
    }

    // Scene 1: The Abyss
    storyTL.to(".narration-s1", { opacity: 1, y: 0, duration: 0.5, onStart: () => showVisualScene(0) })
           .to({}, { duration: 1.0 }); // Pause scene

    const codeStringS1 = `def f(x,l=[]):
  if x in l: return
  l+=[x];[f(i,l) for i in x.__subclasses__()]`;
    const codeObj = { charCount: 0 };
    
    storyTL.to(codeObj, {
      charCount: codeStringS1.length,
      duration: 2.0,
      ease: "none",
      onUpdate: () => {
        const container = document.querySelector('.visual-s1 .code-line-typing');
        if (container) {
          container.innerHTML = highlightPython(codeStringS1.slice(0, Math.floor(codeObj.charCount))) + "<span class='cursor-blink'>_</span>";
        }
      }
    }).to({}, { duration: 1.5 }); // Hold code

    storyTL.to(".narration-s1", { opacity: 0, y: -20, duration: 0.6 })
           .to(".visual-s1", { opacity: 0, scale: 0.95, duration: 0.6 }, "<");

    // Scene 2: Tunnel of Code
    storyTL.to(".narration-s2", { opacity: 1, y: 0, duration: 0.6, onStart: () => showVisualScene(1) })
           .to(".tunnel-plane", { transform: "translateZ(200px)", opacity: 0.9, stagger: 0.05, duration: 2.5 }, "<")
           .to(".btn-teaser-translate", { opacity: 1, duration: 0.5 }, "-=1.0")
           .to({}, { duration: 1.5 })
           .to(".narration-s2", { opacity: 0, y: -20, duration: 0.6 })
           .to(".visual-s2", { opacity: 0, duration: 0.6 }, "<");

    // Scene 3: Morph Translation
    const englishTranslationS3 = "This function traverses Python's class inheritance tree. Starting from any class, it recursively visits every subclass — mapping the entire object hierarchy.";
    const translationObj = { charCount: 0 };

    storyTL.to(".narration-s3", { opacity: 1, y: 0, duration: 0.6, onStart: () => showVisualScene(2) })
           .to(translationObj, {
             charCount: englishTranslationS3.length,
             duration: 2.5,
             ease: "none",
             onUpdate: () => {
               const container = document.querySelector('.visual-s3 .translation-text');
               if (container) {
                 container.innerHTML = englishTranslationS3.slice(0, Math.floor(translationObj.charCount)) + "<span class='cursor-blink'>_</span>";
               }
             }
           }, "<")
           // Spark morph moment at 60% of morph
           .to(".split-divider", { backgroundColor: "var(--amber-glow)", duration: 0.2 }, "-=1.2")
           .to(".aha-overlay", { opacity: 1, scale: 1.0, duration: 0.4 }, "-=1.2")
           .to(".aha-overlay", { opacity: 0, scale: 1.2, duration: 0.5 })
           .to({}, { duration: 1.5 })
           .to(".narration-s3", { opacity: 0, y: -20, duration: 0.6 })
           .to(".visual-s3", { opacity: 0, duration: 0.6 }, "<");

    // Scene 4: Ripple expansion
    storyTL.to(".narration-s4", { opacity: 1, y: 0, duration: 0.6, onStart: () => showVisualScene(3) })
           .to(".visual-s4 .ring", { strokeDashoffset: 0, opacity: 0.6, stagger: 0.1, duration: 2.0 }, "<")
           .to(".visual-s4 .lang-badge", { opacity: 1, scale: 1, stagger: 0.08, duration: 1.5 }, "-=1.5")
           .to(".visual-s4 .stats-ripples", { opacity: 1, scale: 1, duration: 0.8 }, "-=0.6")
           .to({}, { duration: 2.0 })
           .to(".narration-s4", { opacity: 0, y: -20, duration: 0.6 })
           .to(".visual-s4", { opacity: 0, duration: 0.6 }, "<");

    // Scene 5: Terminal Stack
    storyTL.to(".narration-s5", { opacity: 1, y: 0, duration: 0.6, onStart: () => showVisualScene(4) })
           .to(".tc-1", { opacity: 1, y: 0, duration: 0.8 })
           .to(".tc-1 .led-dot", { backgroundColor: '#50fa7b', boxShadow: '0 0 10px #50fa7b', duration: 0.3 })
           .to(".tc-2", { opacity: 1, y: 0, duration: 0.8 }, "-=0.2")
           .to(".tc-2 .led-dot", { backgroundColor: '#50fa7b', boxShadow: '0 0 10px #50fa7b', duration: 0.3 })
           .to(".tc-3", { opacity: 1, y: 0, duration: 0.8 }, "-=0.2")
           .to(".tc-3 .led-dot", { backgroundColor: '#50fa7b', boxShadow: '0 0 10px #50fa7b', duration: 0.3 })
           .to({}, { duration: 2.0 })
           .to(".narration-s5", { opacity: 0, y: -20, duration: 0.6 })
           .to(".visual-s5", { opacity: 0, duration: 0.6 }, "<");

    // Scene 6: Epilogue Final CTA
    storyTL.to(".narration-s6", { opacity: 1, scale: 1, duration: 0.8, onStart: () => showVisualScene(5) })
           .to(".visual-s6 .final-story-cta", { opacity: 1, y: 0, duration: 1.0 })
           .to({}, { duration: 2.5 });

    // 9. Pinned Horizontal Scrolling Step panel
    gsap.to(".horizontal-slides", {
      xPercent: -66.666,
      ease: "none",
      scrollTrigger: {
        trigger: "#how-it-works",
        start: "top top",
        end: "+=200%",
        scrub: 1,
        pin: true
      }
    });

    // 10. Pricing monthly/yearly toggle
    const pricingToggle = document.getElementById('billing-toggle');
    const pricePro = document.getElementById('price-pro');
    const priceTeam = document.getElementById('price-team');
    const billedPro = document.getElementById('billed-pro');
    const billedTeam = document.getElementById('billed-team');
    const labelMonthly = document.getElementById('label-monthly');
    const labelYearly = document.getElementById('label-yearly');
    let isYearly = false;

    pricingToggle.addEventListener('click', () => {
      isYearly = !isYearly;
      if (isYearly) {
        pricingToggle.classList.add('yearly-active');
        labelYearly.classList.add('active');
        labelMonthly.classList.remove('active');
        
        // Update Prices
        gsap.to([pricePro, priceTeam], { opacity: 0, y: -5, duration: 0.15, onComplete: () => {
          pricePro.innerHTML = "₹333<span>/month</span>";
          priceTeam.innerHTML = "₹833<span>/month</span>";
          billedPro.textContent = "Billed ₹3,999 annually";
          billedTeam.textContent = "Billed ₹9,999 annually";
          gsap.to([pricePro, priceTeam], { opacity: 1, y: 0, duration: 0.25 });
        }});
      } else {
        pricingToggle.classList.remove('yearly-active');
        labelMonthly.classList.add('active');
        labelYearly.classList.remove('active');

        // Update Prices
        gsap.to([pricePro, priceTeam], { opacity: 0, y: 5, duration: 0.15, onComplete: () => {
          pricePro.innerHTML = "₹499<span>/month</span>";
          priceTeam.innerHTML = "₹1200<span>/month</span>";
          billedPro.textContent = "";
          billedTeam.textContent = "";
          gsap.to([pricePro, priceTeam], { opacity: 1, y: 0, duration: 0.25 });
        }});
      }
    });

    // 11. FAQ Accordion Trigger
    document.querySelectorAll('.faq-trigger').forEach(trigger => {
      trigger.addEventListener('click', () => {
        const item = trigger.parentNode;
        const isActive = item.classList.contains('active');
        
        // Collapse all items
        document.querySelectorAll('.faq-item').forEach(el => {
          el.classList.remove('active');
          el.querySelector('.faq-content').style.maxHeight = null;
        });

        if (!isActive) {
          item.classList.add('active');
          const content = item.querySelector('.faq-content');
          content.style.maxHeight = content.scrollHeight + 'px';
        }
      });
    });

    // 12. Staggered Scroll Entrance reveals
    gsap.utils.toArray('.reveal-el').forEach(el => {
      gsap.from(el, {
        scrollTrigger: {
          trigger: el,
          start: "top 82%",
          toggleActions: "play none none reverse"
        },
        y: 40,
        opacity: 0,
        duration: 0.8,
        ease: "power3.out"
      });
    });
  </script>
</body>
</html>
