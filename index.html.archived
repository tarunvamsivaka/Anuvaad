        </div>
        
        <!-- Scene 5 -->
        <div class="scene-visual visual-s5">
          <div class="terminals-stack-container">
            <div class="terminal-card tc-1">
              <div class="tc-header">
                <span>Code → English</span>
                <div class="led-dot"></div>
              </div>
              <div class="tc-body">
                <div class="tc-input">@measure_time<br>def query_db(): pass</div>
