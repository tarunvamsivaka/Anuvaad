<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Anuvaad — The AI Code Translator. Translate obscure legacy code into plain English or generate clean production code in 35+ languages instantly.">
  <title>Anuvaad — Stop struggling with legacy code.</title>

  <!-- Favicon -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect fill='%23030507' rx='20' width='100' height='100'/><text x='50' y='72' text-anchor='middle' fill='%23c8860a' font-size='65' font-family='serif' font-weight='bold'>A</text></svg>">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Space+Grotesk:wght@500;600&family=JetBrains+Mono:wght@400;500&family=Lora:ital,wght@1,400&display=swap" rel="stylesheet">

  <!-- Style Sheet -->
  <style>
    /* Design Tokens */
    :root {
      --bg-void:        #030507;   /* Deepest black — canvas bg */
      --bg-deep:        #080c12;   /* Main page background */
      --bg-surface:     #0d1420;   /* Card/panel bg */
      --bg-elevated:    #131c2e;   /* Hover/elevated state */

      --amber-core:     #c8860a;   /* Brand amber */
      --amber-glow:     #f5a623;   /* Bright hover/highlight */
      --amber-dim:      #7a5006;   /* Muted amber border */
      --amber-ghost:    rgba(200, 134, 10, 0.08); /* Subtle amber tint */

      --cyan-core:      #00d4ff;
      --cyan-dim:       #0077a3;
      --cyan-ghost:     rgba(0, 212, 255, 0.06);

      --syn-keyword:    #ff79c6;
      --syn-string:     #f1fa8c;
      --syn-function:   #50fa7b;
      --syn-number:     #bd93f9;
      --syn-comment:    #6272a4;
      --syn-operator:   #ff5555;

      --text-primary:   #e8edf5;
      --text-secondary: #8494b0;
      --text-muted:     #3d4f6e;
      --text-code:      #c9d1d9;

      --glow-amber:     0 0 40px rgba(200, 134, 10, 0.35);
      --glow-cyan:      0 0 40px rgba(0, 212, 255, 0.25);
    }

    /* Reset */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      user-select: none;
      outline: none;
    }

    body {
      background-color: var(--bg-void);
      color: var(--text-primary);
      font-family: 'JetBrains Mono', monospace;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
    }
    ::-webkit-scrollbar-track {
      background: var(--bg-void);
    }
    ::-webkit-scrollbar-thumb {
      background: var(--bg-surface);
      border-radius: 4px;
      border: 2px solid var(--bg-void);
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--amber-dim);
    }

    /* Cursor */
    .custom-cursor {
      width: 8px;
      height: 8px;
      background: var(--amber-glow);
      border-radius: 50%;
      position: fixed;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      mix-blend-mode: difference;
      transition: width 0.2s, height 0.2s, background-color 0.2s;
    }
    .custom-cursor-follower {
      width: 32px;
      height: 32px;
      border: 1px solid var(--amber-dim);
      border-radius: 50%;
      position: fixed;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      transition: transform 0.08s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.2s;
    }

    /* General Layout */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      position: relative;
    }

    section {
      position: relative;
      padding: 120px 0;
      z-index: 5;
    }

    /* Typography */
    h1, h2, h3 {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
    }

    .headline-large {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    /* Buttons */
    .btn-amber {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background-color: var(--amber-core);
      color: var(--bg-void);
      padding: 14px 28px;
      border-radius: 8px;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      text-decoration: none;
      border: none;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      transition: transform 0.2s, box-shadow 0.2s, background-color 0.2s;
      box-shadow: 0 4px 20px rgba(200, 134, 10, 0.25);
    }
    .btn-amber:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(245, 166, 35, 0.45);
      background-color: var(--amber-glow);
    }
    .btn-amber::after {
      content: '';
      position: absolute;
      top: 0;
      left: -50%;
      width: 200%;
      height: 100%;
      background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.3), transparent);
      transform: skewX(-30deg);
      transition: 0.75s;
      opacity: 0;
    }
    .btn-amber:hover::after {
      left: 125%;
      opacity: 1;
    }

    .btn-outline {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: transparent;
      border: 1px solid var(--amber-dim);
      color: var(--text-primary);
      padding: 14px 28px;
      border-radius: 8px;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 600;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      text-decoration: none;
      cursor: pointer;
      transition: background-color 0.3s, border-color 0.3s, transform 0.2s;
    }
    .btn-outline:hover {
      background-color: var(--amber-ghost);
      border-color: var(--amber-glow);
      transform: translateY(-2px);
    }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      color: var(--text-secondary);
      padding: 8px 16px;
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 500;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      text-decoration: none;
      cursor: pointer;
      transition: color 0.3s;
    }
    .btn-ghost:hover {
      color: var(--text-primary);
    }

    /* ① LOADING SCREEN */
    .loader-overlay {
      position: fixed;
      inset: 0;
      background-color: var(--bg-void);
      z-index: 10000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: transform 0.8s cubic-bezier(0.85, 0, 0.15, 1);
    }
    .loader-svg {
      width: 120px;
      height: 120px;
      margin-bottom: 24px;
    }
    .loader-path {
      stroke: var(--amber-core);
      stroke-width: 4;
      fill: none;
      stroke-dasharray: 400;
      stroke-dashoffset: 400;
      animation: drawStroke 2s ease-in-out forwards;
    }
    .loader-text {
      font-family: 'Syne', sans-serif;
      font-size: 2.2rem;
      font-weight: 800;
      letter-spacing: 0.3em;
      margin-left: 0.3em; /* Balance spacing */
      color: var(--text-primary);
    }
    .loader-text .letter {
      opacity: 0;
      display: inline-block;
    }
    .loader-tagline {
      font-size: 0.85rem;
      color: var(--text-secondary);
      letter-spacing: 0.15em;
      margin-top: 12px;
      opacity: 0;
      font-style: italic;
    }
    .loader-scanline {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: linear-gradient(to right, transparent, var(--amber-glow), transparent);
      opacity: 0.4;
      animation: sweepLine 2.5s infinite linear;
    }

    @keyframes drawStroke {
      to {
        stroke-dashoffset: 0;
      }
    }
    @keyframes sweepLine {
      0% { top: 0%; }
      100% { top: 100%; }
    }

    /* ② NAVIGATION */
    .nav-glass {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      background: rgba(3, 5, 7, 0.75);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(200, 134, 10, 0.08);
      height: 72px;
      display: flex;
      align-items: center;
      transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    }
    .nav-glass.nav-hidden {
      transform: translateY(-100%);
    }
    .nav-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
    }
    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.4rem;
      color: var(--text-primary);
      text-decoration: none;
      display: flex;
      align-items: center;
    }
    .nav-dot {
      color: var(--amber-core);
      animation: pulseDot 1.5s infinite alternate;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 32px;
      list-style: none;
    }
    .nav-links a {
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      position: relative;
      padding: 6px 0;
      transition: color 0.3s;
    }
    .nav-links a:hover {
      color: var(--text-primary);
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background-color: var(--amber-glow);
      transition: width 0.3s;
      border-radius: 2px;
    }
    .nav-links a:hover::after {
      width: 100%;
    }
    .nav-cta {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .nav-cta .btn-amber {
      padding: 10px 20px;
    }

    @keyframes pulseDot {
      from { transform: scale(0.9); opacity: 0.6; }
      to { transform: scale(1.3); opacity: 1; filter: drop-shadow(0 0 4px var(--amber-glow)); }
    }

    /* Mobile Menu Drawer Toggle */
    .mobile-toggle {
      display: none;
      background: transparent;
      border: none;
      color: var(--text-primary);
      cursor: pointer;
    }
    .mobile-toggle svg {
      transition: transform 0.3s ease;
    }
    .mobile-toggle .line {
      transition: transform 0.3s ease, opacity 0.3s ease;
      transform-origin: center;
    }
    .mobile-toggle.active .line.top {
      transform: translateY(6px) rotate(45deg);
    }
    .mobile-toggle.active .line.middle {
      opacity: 0;
    }
    .mobile-toggle.active .line.bottom {
      transform: translateY(-6px) rotate(-45deg);
    }

    /* ③ HERO SECTION */
    .hero-section {
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      padding: 0;
    }
    .canvas-background {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
    }
    .hero-overlay {
      position: relative;
      z-index: 2;
      text-align: center;
      max-width: 900px;
      width: 100%;
    }
    .hero-pretitle {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--amber-glow);
      letter-spacing: 0.3em;
      text-transform: uppercase;
      margin-bottom: 24px;
      opacity: 0;
    }
    .hero-title {
      font-size: 4rem;
      line-height: 1.1;
      margin-bottom: 24px;
      color: var(--text-primary);
    }
    .hero-title span {
      display: block;
      opacity: 0;
      transform: translateY(30px);
    }
    .hero-subheadline {
      font-size: 1.3rem;
      color: var(--text-secondary);
      margin-bottom: 40px;
      height: 30px;
      opacity: 0;
    }
    .hero-subheadline-cycle {
      color: var(--text-primary);
      font-weight: 500;
      border-right: 2px solid var(--amber-glow);
      padding-right: 4px;
    }
    .hero-ctas {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      margin-bottom: 60px;
      opacity: 0;
      transform: translateY(20px);
    }
    .hero-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding-top: 40px;
      opacity: 0;
      transform: translateY(20px);
    }
    .hero-stat-card h4 {
      font-family: 'Syne', sans-serif;
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--amber-core);
      margin-bottom: 4px;
    }
    .hero-stat-card p {
      font-size: 0.75rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .scroll-cue {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      z-index: 2;
      opacity: 0.8;
      transition: opacity 0.3s;
    }
    .scroll-cue p {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.25em;
      color: var(--text-secondary);
    }
    .scroll-line {
      width: 1px;
      height: 50px;
      background: linear-gradient(to bottom, var(--amber-dim), transparent);
      position: relative;
      overflow: hidden;
    }
    .scroll-line::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 15px;
      background-color: var(--amber-glow);
      animation: scrollLineAnim 2s infinite ease-in-out;
    }

    @keyframes scrollLineAnim {
      0% { top: -20px; }
      100% { top: 60px; }
    }

    /* ④ THE STORY CHAPTER */
    .story-section {
      height: 600vh;
      padding: 0;
      position: relative;
      background-color: var(--bg-void);
    }
    .story-sticky-container {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background-color: var(--bg-void);
    }
    .story-bg-grid {
      position: absolute;
      inset: 0;
      background-image: 
        radial-gradient(rgba(200, 134, 10, 0.03) 1px, transparent 1px),
        radial-gradient(rgba(0, 212, 255, 0.02) 1px, transparent 1px);
      background-size: 40px 40px;
      background-position: 0 0, 20px 20px;
      z-index: 1;
    }
    .story-noise-overlay {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, transparent, var(--bg-void) 85%),
                  url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.015'/%3E%3C/svg%3E");
      z-index: 2;
      pointer-events: none;
    }
    .story-narration-wrapper {
      position: absolute;
      top: 15%;
      z-index: 10;
      width: 100%;
      max-width: 800px;
      padding: 0 24px;
      display: flex;
      justify-content: center;
      pointer-events: none;
    }
    .story-narration {
      font-family: 'Lora', Georgia, serif;
      font-style: italic;
      text-align: center;
      font-size: 1.35rem;
      line-height: 1.8;
      color: var(--text-primary);
      opacity: 0;
      transform: translateY(20px);
      position: absolute;
      width: 100%;
    }
    .story-visuals-container {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 5;
    }
    .scene-visual {
      position: absolute;
      opacity: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      max-width: 850px;
      padding: 0 24px;
      pointer-events: none;
    }
    .scene-visual.active-visual {
      pointer-events: auto;
    }

    /* Common Terminals style */
    .code-terminal {
      background: #06090e;
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 12px;
      width: 100%;
      max-width: 580px;
      box-shadow: 0 10px 50px rgba(0,0,0,0.8), 0 0 30px rgba(200,134,10,0.03);
      overflow: hidden;
    }
    .terminal-header {
      background: #0a0e14;
      padding: 12px 18px;
      border-bottom: 1px solid rgba(255,255,255,0.03);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .terminal-header .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    .terminal-header .dot.red { background-color: #ff5555; }
    .terminal-header .dot.yellow { background-color: #f5a623; }
    .terminal-header .dot.green { background-color: #50fa7b; }
    .terminal-header .terminal-title {
      font-size: 0.7rem;
      color: var(--text-secondary);
      margin-left: 10px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .terminal-body {
      padding: 24px;
      min-height: 130px;
      color: var(--text-code);
      font-family: 'JetBrains Mono', monospace;
      line-height: 1.6;
    }
    .cursor-blink {
      display: inline-block;
      width: 8px;
      background-color: var(--amber-glow);
      margin-left: 2px;
      animation: blinkCursor 0.8s infinite;
    }
    @keyframes blinkCursor {
      50% { opacity: 0; }
    }

    /* Syntax Highlighting */
    .syn-keyword { color: var(--syn-keyword); font-weight: 500; }
    .syn-string { color: var(--syn-string); }
    .syn-function { color: var(--syn-function); }
    .syn-number { color: var(--syn-number); }
    .syn-comment { color: var(--syn-comment); font-style: italic; }
    .syn-operator { color: var(--syn-operator); }

    /* Scene 2 Code Tunnel */
    .tunnel-container {
      width: 400px;
      height: 300px;
      perspective: 800px;
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(0, 212, 255, 0.1);
      border-radius: 16px;
      background: rgba(3, 5, 7, 0.6);
      box-shadow: 0 0 40px rgba(0, 212, 255, 0.05);
    }
    .tunnel-plane {
      position: absolute;
      width: 100%;
      height: 100%;
      transform-style: preserve-3d;
      pointer-events: none;
      display: flex;
      flex-direction: column;
      justify-content: space-around;
      padding: 20px;
      opacity: 0.6;
      font-size: 0.65rem;
      color: var(--amber-dim);
    }
    .tunnel-left { transform: rotateY(90deg) translateZ(-200px); }
    .tunnel-right { transform: rotateY(-90deg) translateZ(-200px); }
    .tunnel-top { transform: rotateX(-90deg) translateZ(-150px); }
    .tunnel-bottom { transform: rotateX(90deg) translateZ(-150px); }

    .btn-teaser-translate {
      margin-top: 30px;
      opacity: 0.5;
      cursor: not-allowed;
      border: 1px solid var(--amber-dim);
    }

    /* Scene 3 Morph Split */
    .split-layout {
      display: flex;
      width: 100%;
      max-width: 680px;
      background: #06090e;
      border: 1px solid rgba(255,255,255,0.05);
      border-radius: 12px;
      overflow: hidden;
      height: 200px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.8);
    }
    .split-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .split-panel .panel-header {
      background: #0a0e14;
      padding: 10px 16px;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-secondary);
      border-bottom: 1px solid rgba(255,255,255,0.03);
    }
    .split-panel .panel-content {
      padding: 20px;
      overflow: auto;
      font-size: 0.7rem;
      line-height: 1.6;
      height: 100%;
    }
    .split-divider {
      width: 1px;
      background-color: rgba(255,255,255,0.05);
      position: relative;
    }
    .panel-right {
      background: rgba(200, 134, 10, 0.01);
    }
    .translation-text {
      color: var(--text-primary);
    }
    .aha-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      opacity: 0;
      transform: scale(0.8);
      z-index: 20;
    }
    .aha-text {
      font-family: 'Syne', sans-serif;
      font-size: 4rem;
      font-weight: 800;
      color: var(--amber-glow);
      text-shadow: 0 0 50px rgba(245, 166, 35, 0.4);
      letter-spacing: 0.15em;
    }

    /* Scene 4 SVG concentric rings */
    .ripple-rings-wrapper {
      position: relative;
      width: 400px;
      height: 400px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .ripple-svg {
      position: absolute;
      width: 100%;
      height: 100%;
    }
    .ripple-svg .ring {
      fill: none;
      stroke: var(--text-muted);
      stroke-width: 1;
      opacity: 0.25;
      stroke-dasharray: 1000;
      transform-origin: center;
    }
    .ripple-svg .ring-1 { stroke: #3572A5; }
    .ripple-svg .ring-2 { stroke: #00ADD8; }
    .ripple-svg .ring-3 { stroke: #dea584; }
    .ripple-svg .ring-4 { stroke: #ffac45; }

    .lang-badge {
      position: absolute;
      background: var(--bg-surface);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 20px;
      padding: 6px 14px;
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--text-primary);
      box-shadow: 0 4px 15px rgba(0,0,0,0.5);
      display: flex;
      align-items: center;
      gap: 6px;
      transform: translate(-50%, -50%);
      top: 50%;
      left: 50%;
      margin-top: calc(var(--dist) * sin(var(--angle)));
      margin-left: calc(var(--dist) * cos(var(--angle)));
      opacity: 0;
      scale: 0.5;
    }
    .lang-badge::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background-color: var(--badge-color);
    }
    .stats-ripples {
      position: absolute;
      display: flex;
      flex-direction: column;
      gap: 8px;
      background: rgba(3, 5, 7, 0.85);
      padding: 16px;
      border-radius: 12px;
      border: 1px solid rgba(200,134,10,0.1);
      box-shadow: 0 10px 30px rgba(0,0,0,0.6);
      width: 210px;
      z-index: 10;
      backdrop-filter: blur(10px);
    }
    .stat-bubble {
      font-size: 0.7rem;
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .stat-bubble span {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: bold;
      color: var(--amber-glow);
    }

    /* Scene 5 Stack terminals */
    .terminals-stack-container {
      width: 100%;
      max-width: 540px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      position: relative;
    }
    .terminal-card {
      background: #06090e;
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 10px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.6);
      overflow: hidden;
      opacity: 0;
      transform: translateY(20px);
      transition: border-color 0.3s;
    }
    .terminal-card:hover {
      border-color: rgba(200, 134, 10, 0.15);
    }
    .tc-header {
      background: #090d14;
      padding: 10px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid rgba(255,255,255,0.02);
    }
    .tc-header span {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-secondary);
      font-weight: 500;
    }
    .tc-header .led-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background-color: var(--text-muted);
      box-shadow: 0 0 6px rgba(255,255,255,0.1);
      transition: background-color 0.3s, box-shadow 0.3s;
    }
    .tc-body {
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .tc-input {
      color: var(--text-code);
      font-size: 0.7rem;
    }
    .tc-output {
      color: var(--amber-glow);
      font-size: 0.7rem;
      border-left: 2px solid var(--amber-dim);
      padding-left: 8px;
      margin-top: 4px;
    }

    /* Scene 6 Epilogue final CTA */
    .final-story-cta {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      text-align: center;
      opacity: 0;
      transform: translateY(30px);
    }
    .btn-story-cta {
      font-size: 1rem;
      padding: 16px 36px;
      box-shadow: var(--glow-amber);
    }
    .btn-story-cta-sub {
      font-size: 0.75rem;
      color: var(--text-secondary);
      letter-spacing: 0.05em;
    }

    /* ⑤ FEATURES */
    .features-section {
      background-color: var(--bg-deep);
      border-top: 1px solid rgba(255, 255, 255, 0.03);
    }
    .section-header {
      margin-bottom: 64px;
      max-width: 650px;
    }
    .section-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid rgba(200, 134, 10, 0.2);
      background: var(--amber-ghost);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--amber-glow);
      font-weight: 600;
      margin-bottom: 20px;
    }
    .section-title {
      font-size: 2.8rem;
      line-height: 1.15;
      color: var(--text-primary);
      margin-bottom: 20px;
    }
    .section-title span {
      background: linear-gradient(135deg, var(--amber-glow), var(--cyan-core));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .section-desc {
      font-size: 1rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .feature-card {
      background: rgba(13, 20, 32, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 16px;
      padding: 32px;
      transition: transform 0.4s, border-color 0.4s, box-shadow 0.4s;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      position: relative;
      overflow: hidden;
    }
    .feature-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(200, 134, 10, 0.04), transparent);
      opacity: 0;
      transition: opacity 0.4s;
    }
    .feature-card:hover {
      transform: translateY(-4px);
      border-color: rgba(200, 134, 10, 0.2);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(200, 134, 10, 0.04);
    }
    .feature-card:hover::after {
      opacity: 1;
    }
    .feature-icon {
      width: 44px;
      height: 44px;
      background: rgba(200, 134, 10, 0.06);
      border: 1px solid rgba(200, 134, 10, 0.15);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--amber-glow);
      margin-bottom: 24px;
      transition: background-color 0.3s, border-color 0.3s, box-shadow 0.3s;
    }
    .feature-card:hover .feature-icon {
      background: rgba(200, 134, 10, 0.15);
      border-color: var(--amber-glow);
      box-shadow: 0 0 15px rgba(200, 134, 10, 0.2);
    }
    .feature-card h3 {
      font-size: 1.25rem;
      color: var(--text-primary);
      margin-bottom: 12px;
    }
    .feature-card p {
      font-size: 0.8rem;
      line-height: 1.6;
      color: var(--text-secondary);
    }
    .feature-card-large {
      grid-column: span 1;
    }
    .feature-preview {
      margin-top: 20px;
      border: 1px solid rgba(200, 134, 10, 0.1);
      border-radius: 8px;
      background: rgba(3, 5, 7, 0.6);
      padding: 16px;
    }
    .feature-preview p {
      font-size: 0.6rem;
      color: var(--amber-glow);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 8px;
    }
    .feature-preview code {
      font-size: 0.7rem;
      color: var(--text-code);
      font-style: italic;
    }

    /* ⑥ HOW IT WORKS */
    .how-section {
      height: 300vh;
      padding: 0;
      position: relative;
    }
    .horizontal-sticky {
      position: sticky;
      top: 0;
      height: 100vh;
      width: 100%;
      overflow: hidden;
    }
    .horizontal-slides {
      display: flex;
      width: 300vw;
      height: 100%;
    }
    .horizontal-slide {
      width: 100vw;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: var(--bg-void);
      position: relative;
    }
    .slide-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 64px;
      align-items: center;
      width: 100%;
      max-width: 1100px;
      padding: 0 40px;
    }
    .slide-num {
      font-family: 'Syne', sans-serif;
      font-size: 8rem;
      font-weight: 800;
      color: rgba(200, 134, 10, 0.04);
      line-height: 1;
      position: absolute;
      top: 10%;
      left: 10%;
      z-index: 1;
    }
    .slide-content {
      position: relative;
      z-index: 2;
    }
    .slide-content h3 {
      font-size: 2.2rem;
      color: var(--text-primary);
      margin-bottom: 20px;
      line-height: 1.2;
    }
    .slide-content p {
      font-size: 0.95rem;
      color: var(--text-secondary);
      line-height: 1.7;
    }
    .slide-illustration {
      height: 320px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(255,255,255,0.03);
      border-radius: 20px;
      background: rgba(13,20,32,0.3);
      backdrop-filter: blur(10px);
      box-shadow: inset 0 0 20px rgba(255,255,255,0.01);
      position: relative;
      overflow: hidden;
    }
    .step-svg {
      width: 160px;
      height: 160px;
    }

    /* ⑦ USE CASES BENTO GRID */
    .bento-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .bento-card {
      background: rgba(13, 20, 32, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 16px;
      padding: 32px;
      min-height: 240px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      position: relative;
      overflow: hidden;
      transition: transform 0.4s, border-color 0.4s, box-shadow 0.4s;
    }
    .bento-card:hover {
      transform: translateY(-4px);
      border-color: rgba(200, 134, 10, 0.2);
      box-shadow: 0 12px 40px rgba(0,0,0,0.6);
    }
    .bento-card-bg-code {
      position: absolute;
      inset: 20px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.55rem;
      color: rgba(200, 134, 10, 0.01);
      line-height: 1.5;
      overflow: hidden;
      pointer-events: none;
      transition: color 0.4s;
    }
    .bento-card:hover .bento-card-bg-code {
      color: rgba(200, 134, 10, 0.04);
    }
    .bento-card-large {
      grid-column: span 2;
    }
    .bento-card h3 {
      font-size: 1.25rem;
      color: var(--text-primary);
      margin-bottom: 8px;
      position: relative;
      z-index: 2;
    }
    .bento-card p {
      font-size: 0.8rem;
      color: var(--text-secondary);
      line-height: 1.6;
      position: relative;
      z-index: 2;
    }

    /* ⑧ PRICING SECTION */
    .pricing-section {
      background-color: var(--bg-deep);
    }
    .pricing-toggle-container {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-top: 32px;
      margin-bottom: 64px;
    }
    .pricing-toggle-label {
      font-size: 0.85rem;
      color: var(--text-secondary);
      font-weight: 500;
    }
    .pricing-toggle-label.active {
      color: var(--text-primary);
    }
    .pricing-toggle {
      width: 64px;
      height: 32px;
      background: var(--bg-surface);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 20px;
      position: relative;
      cursor: pointer;
      display: flex;
      align-items: center;
      padding: 4px;
    }
    .pricing-toggle-pill {
      width: 22px;
      height: 22px;
      background: var(--amber-core);
      border-radius: 50%;
      position: absolute;
      left: 4px;
      transition: left 0.3s cubic-bezier(0.25, 1, 0.5, 1), background-color 0.3s;
      box-shadow: 0 2px 10px rgba(200, 134, 10, 0.4);
    }
    .pricing-toggle.yearly-active .pricing-toggle-pill {
      left: 36px;
      background-color: var(--amber-glow);
    }
    .pricing-save-badge {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      color: #10b981;
      font-size: 0.65rem;
      font-weight: bold;
      padding: 4px 10px;
      border-radius: 12px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      align-items: stretch;
    }
    .pricing-card {
      background: rgba(13, 20, 32, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 20px;
      padding: 40px;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      transition: transform 0.4s, border-color 0.4s, box-shadow 0.4s;
    }
    .pricing-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(200,134,10,0.03) 0%, transparent 40%);
      opacity: 0;
      transition: opacity 0.4s;
    }
    .pricing-card:hover {
      transform: translateY(-6px);
      border-color: rgba(200, 134, 10, 0.15);
      box-shadow: 0 20px 40px rgba(0,0,0,0.7);
    }
    .pricing-card:hover::before {
      opacity: 1;
    }
    .pricing-card.popular {
      border-color: rgba(200, 134, 10, 0.3);
      background: linear-gradient(to bottom, rgba(200, 134, 10, 0.05) 0%, rgba(13, 20, 32, 0.5) 50%, rgba(13, 20, 32, 0.5) 100%);
      box-shadow: 0 0 60px rgba(200, 134, 10, 0.06);
      transform: scale(1.02);
    }
    .pricing-card.popular:hover {
      box-shadow: 0 20px 50px rgba(200, 134, 10, 0.12);
      transform: scale(1.02) translateY(-4px);
    }
    .pricing-badge {
      position: absolute;
      top: 20px;
      right: 20px;
      background: var(--amber-core);
      color: var(--bg-void);
      font-size: 0.6rem;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 12px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .pricing-card h3 {
      font-size: 1.5rem;
      color: var(--text-primary);
      margin-bottom: 8px;
    }
    .pricing-desc {
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin-bottom: 32px;
      min-height: 40px;
    }
    .pricing-price {
      font-family: 'Syne', sans-serif;
      font-size: 3.5rem;
      font-weight: 800;
      color: var(--text-primary);
      line-height: 1;
      display: flex;
      align-items: baseline;
      gap: 4px;
      margin-bottom: 8px;
    }
    .pricing-price span {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.9rem;
      color: var(--text-muted);
      font-weight: 500;
    }
    .pricing-billed-note {
      font-size: 0.7rem;
      color: var(--amber-glow);
      font-weight: 600;
      min-height: 15px;
      margin-bottom: 24px;
    }
    .pricing-features {
      list-style: none;
      margin-top: 32px;
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      gap: 16px;
      border-top: 1px solid rgba(255,255,255,0.03);
      padding-top: 32px;
    }
    .pricing-features li {
      font-size: 0.8rem;
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .pricing-features svg {
      width: 14px;
      height: 14px;
      color: var(--amber-core);
      flex-shrink: 0;
    }

    /* ⑨ FAQ ACCORDION */
    .faq-wrapper {
      max-width: 760px;
      margin: 0 auto;
    }
    .faq-item {
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }
    .faq-trigger {
      width: 100%;
      background: transparent;
      border: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 24px 0;
      cursor: pointer;
      text-align: left;
    }
    .faq-trigger h3 {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-secondary);
      transition: color 0.3s;
    }
    .faq-trigger:hover h3 {
      color: var(--text-primary);
    }
    .faq-icon {
      font-size: 1.5rem;
      color: var(--amber-core);
      font-family: 'Space Grotesk', sans-serif;
      line-height: 1;
      transition: transform 0.3s, color 0.3s;
    }
    .faq-content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    }
    .faq-content p {
      font-size: 0.8rem;
      line-height: 1.6;
      color: var(--text-secondary);
      padding-bottom: 24px;
    }

    /* Active Accordion State */
    .faq-item.active .faq-trigger h3 {
      color: var(--text-primary);
    }
    .faq-item.active .faq-icon {
      transform: rotate(45deg);
      color: var(--amber-glow);
    }

    /* ⑩ FOOTER */
    .footer {
      background-color: var(--bg-void);
      border-top: 1px solid rgba(255, 255, 255, 0.03);
      padding: 64px 0 32px;
      font-size: 0.75rem;
      color: var(--text-secondary);
    }
    .footer-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 48px;
    }
    .footer-brand h4 {
      font-family: 'Syne', sans-serif;
      font-size: 1.3rem;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 12px;
    }
    .footer-brand p {
      max-width: 320px;
      line-height: 1.6;
    }
    .footer-nav {
      display: flex;
      gap: 64px;
    }
    .footer-nav-col h5 {
      color: var(--text-primary);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 16px;
      font-size: 0.7rem;
    }
    .footer-nav-col ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .footer-nav-col a {
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.3s;
    }
    .footer-nav-col a:hover {
      color: var(--amber-glow);
    }
    .footer-bottom {
      border-top: 1px solid rgba(255, 255, 255, 0.03);
      padding-top: 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .footer-socials {
      display: flex;
      gap: 16px;
    }
    .footer-socials a {
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.3s;
    }
    .footer-socials a:hover {
      color: var(--text-primary);
    }

    /* RESPONSIVE LAYOUT */
    @media (max-width: 992px) {
      .features-grid, .pricing-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .bento-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .bento-card-large {
        grid-column: span 2;
      }
    }

    @media (max-width: 768px) {
      .custom-cursor, .custom-cursor-follower {
        display: none;
      }
      .nav-links {
        display: none;
      }
      .nav-cta {
        display: none;
      }
      .mobile-toggle {
        display: block;
      }
      .hero-title {
        font-size: 2.6rem;
      }
      .hero-stats {
        grid-template-columns: repeat(2, 1fr);
      }
      .features-grid, .pricing-grid, .bento-grid {
        grid-template-columns: 1fr;
      }
      .bento-card-large {
        grid-column: span 1;
      }
      .slide-grid {
        grid-template-columns: 1fr;
        gap: 32px;
      }
      .slide-illustration {
        height: 200px;
      }
      .footer-top {
        flex-direction: column;
        gap: 40px;
      }
      .footer-nav {
        width: 100%;
        justify-content: space-between;
        gap: 20px;
      }
    }
  </style>
</head>
<body>

  <!-- Custom Cursor Elements -->
  <div class="custom-cursor"></div>
  <div class="custom-cursor-follower"></div>

  <!-- Loading Screen -->
  <div id="loader" class="loader-overlay">
    <div class="loader-scanline"></div>
    <svg class="loader-svg" viewBox="0 0 100 100">
      <path class="loader-path" d="M15,85 L50,15 L85,85 M30,60 L70,60" />
    </svg>
    <div class="loader-text"><span class="letter">A</span><span class="letter">N</span><span class="letter">U</span><span class="letter">V</span><span class="letter">A</span><span class="letter">A</span><span class="letter">D</span></div>
    <div class="loader-tagline">Understanding code, one word at a time.</div>
  </div>

  <!-- ② NAVIGATION -->
  <header class="nav-glass">
    <div class="container nav-container">
      <a href="#" class="nav-logo">
        Anuvaad<span class="nav-dot">·</span>
      </a>
      <ul class="nav-links">
        <li><a href="#features">Features</a></li>
        <li><a href="#story">Story</a></li>
        <li><a href="#how-it-works">How It Works</a></li>
        <li><a href="#pricing">Pricing</a></li>
        <li><a href="#faq">FAQ</a></li>
      </ul>
      <div class="nav-cta">
        <a href="/signin" class="btn-ghost">Sign In</a>
        <a href="/signup" class="btn-amber">Start Free</a>
      </div>
      <button class="mobile-toggle" aria-label="Toggle Menu">
        <svg style="width: 24px; height: 24px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path class="line top" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16"></path>
          <path class="line middle" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12h16"></path>
          <path class="line bottom" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 18h16"></path>
        </svg>
      </button>
    </div>
  </header>

  <!-- ③ HERO SECTION -->
  <section class="hero-section">
    <canvas id="hero-canvas" class="canvas-background"></canvas>
    <div class="container hero-overlay">
      <div class="hero-pretitle">The AI Code Translator</div>
      <h1 class="hero-title headline-large">
        <span class="word-1">Stop Struggling</span>
