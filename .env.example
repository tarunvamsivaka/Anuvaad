# =============================================================================
# Anuvaad Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] enable additional features when provided.
# =============================================================================

# ---------- AI Models [REQUIRED] ----------
# Groq — Primary model for code explanations (Llama 3.3 70B)
# Sign up at https://console.groq.com and create an API key
GROQ_API_KEY=your_groq_api_key_here

# DeepSeek — Primary model for code generation (V3), Pro reasoning (R1)
# Sign up at https://platform.deepseek.com and create an API key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ---------- Supabase [REQUIRED] ----------
# SUPABASE_URL: Your project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# SUPABASE_ANON_KEY: Public key (safe for client-side, used for JWT verification)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# SUPABASE_SERVICE_ROLE_KEY: PRIVATE key for server-side DB writes (NEVER expose to client!)
# Get from: Supabase Dashboard → Settings → API → service_role key
# This is used by Razorpay webhooks to update user_subscriptions table.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ---------- Frontend URL [REQUIRED in production] ----------
# The URL where your frontend is hosted, used for CORS and Razorpay redirects.
# CRITICAL: Set this to your actual production domain (e.g., https://anuvaad.dev)
FRONTEND_URL=http://localhost:3000

# ---------- PostgreSQL [REQUIRED] ----------
# Direct connection URL (used by Alembic for migrations, and by the app in dev)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[password]@db.lbqgvehjtbfkxawbznwd.supabase.co:5432/postgres

# PgBouncer connection pooler URL (RECOMMENDED for production with multiple workers)
# Prevents connection exhaustion across Gunicorn workers. Uses port 6543.
# Get from: Supabase Dashboard → Project Settings → Database → Connection pooling → URI (Transaction mode)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_POOL_URL=postgresql://postgres.lbqgvehjtbfkxawbznwd:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ---------- GitHub OAuth [REQUIRED for GitHub Integration] ----------
# Create a GitHub OAuth App in Developer Settings.
# Set Homepage URL to your FRONTEND_URL and Authorization callback URL to:
# <FRONTEND_URL>/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here


# ---------- Razorpay [For Billing] ----------
# Get Key ID + Key Secret from Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Create a Subscription Plan under Subscriptions → Plans and paste the ID here
RAZORPAY_PRO_PLAN_ID=plan_your_plan_id_here

# Razorpay webhook secret for verifying webhook signature
# Get this from: Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ---------- Redis [RECOMMENDED — required for production] ----------
# Standard Redis connection URL (for Docker, local, or managed Redis)
# REDIS_URL=redis://localhost:6379

# OR Upstash Redis REST (serverless alternative)
# UPSTASH_REDIS_URL=your_upstash_redis_rest_url_here
# UPSTASH_REDIS_TOKEN=your_upstash_redis_rest_token_here

# ---------- Sentry Error Monitoring [OPTIONAL] ----------
# Get your DSN from your Sentry project settings
SENTRY_DSN=your_sentry_dsn_here

# ---------- Resend — Transactional Email Service [OPTIONAL] ----------
# Sign up for free at https://resend.com (100 emails/day, no credit card)
# Get your API key from: Resend Dashboard → API Keys
# Used for: welcome emails, subscription confirmations, milestone celebrations
RESEND_API_KEY=your_resend_api_key_here

# Optional: Customize the "from" address (requires a verified domain on Resend)
# EMAIL_FROM=Anuvaad <notifications@anuvaad.dev>

# ---------- Metrics Endpoint Auth [OPTIONAL] ----------
# HTTP Basic Auth for /api/metrics and /api/metrics/prometheus
# Leave blank to allow unauthenticated access in dev.
METRICS_USERNAME=admin
METRICS_PASSWORD=your_secure_metrics_password_here

# ---------- Environment [OPTIONAL] ----------
# Set to "production" to enforce strict env var validation at startup.
# ENV=production

# ---------- Launch & Resilience Settings [OPTIONAL] ----------
# Feature flag to temporarily disable Razorpay payments (default: false)
ENABLE_BILLING=false

# Admin users whitelist (comma-separated email addresses)
ADMIN_USERS=admin@anuvaad.dev

# Trusted users whitelist (comma-separated email addresses)
TRUSTED_USERS=trusted@anuvaad.dev

# User Quota Limits (defaults will apply if unset)
LIMIT_FREE_DAILY=10
LIMIT_FREE_CHARS=10000
LIMIT_PRO_DAILY=999999
LIMIT_PRO_CHARS=50000

# Platform Daily Translation Cap (to dynamically scale protection levels)
# If set, protection modes (Caution, Restricted, Emergency) will scale based on this daily cap.
PLATFORM_DAILY_CAP_TRANSLATIONS=1000

# Manual Protection Mode Override (NORMAL, CAUTION, RESTRICTED, EMERGENCY)
# PROTECTION_MODE=NORMAL

# Emergency Mode override flag (forces EMERGENCY protection level immediately)
EMERGENCY_MODE_FLAG=false

# =============================================================================
# SECURITY FIXES (Phase 1 — added 2026-07)
# =============================================================================

# ---------- GitHub Token Encryption [REQUIRED for production] ----------
# FIX-01 (P0-01): Fernet key to encrypt GitHub OAuth tokens at rest.
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store ONLY in a secrets manager (Vault, AWS Secrets Manager, Railway Secrets).
# NEVER commit the real key to source control.
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

# ---------- Supabase JWT Secret [REQUIRED] ----------
# FIX-04 (P0-04): Used for local JWT verification (zero outbound HTTP per request).
# Found in: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ---------- OpenRouter API Key [OPTIONAL — LLM fallback provider] ----------
# FIX-24 (P1-03): Second LLM provider for automatic fallback when Groq is down.
# Sign up at https://openrouter.ai and create an API key.
OPENROUTER_API_KEY=your_openrouter_api_key_here
