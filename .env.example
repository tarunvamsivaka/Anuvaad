GEMINI_API_KEY=your_gemini_api_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PRO_PRICE_ID=price_your_stripe_price_id_here

# Stripe webhook secret for verifying webhook signatures
# Get this from: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# The URL where your frontend is hosted, used for CORS and Stripe redirects.
# CRITICAL: Set this to your actual production domain (e.g., https://anuvaad.dev)
FRONTEND_URL=http://127.0.0.1:5500

# Supabase — Server-side configuration
# SUPABASE_URL: Your project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# SUPABASE_ANON_KEY: Public key (safe for client-side, used for JWT verification)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# SUPABASE_SERVICE_ROLE_KEY: PRIVATE key for server-side DB writes (NEVER expose to client!)
# Get from: Supabase Dashboard → Settings → API → service_role key
# This is used by Stripe webhooks to update user_subscriptions table.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
